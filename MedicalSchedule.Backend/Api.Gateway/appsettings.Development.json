{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Keycloak": {
    "BaseUrl": "https://localhost:8081",
    "Realm": "medical-schedule",
    "ClientId": "medical-schedule-app",
    "AdminUser": "admin",
    "AdminPassword": "thiagozika"
  },
  "Registry": {
    "BaseUrl": "http://localhost:5241"
  },
  "ReverseProxy": {
    "Routes": {
      "registry-owners": {
        "ClusterId": "registry",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/owners/{**catch-all}" }
      },
      "registry-vets": {
        "ClusterId": "registry",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/vets/{**catch-all}" }
      },
      "registry-pets": {
        "ClusterId": "registry",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/pets/{**catch-all}" }
      },
      "scheduling-consultations": {
        "ClusterId": "scheduling",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/consultations/{**catch-all}" }
      }
    },
    "Clusters": {
      "registry": {
        "Destinations": {
          "default": { "Address": "http://localhost:5241" }
        }
      },
      "scheduling": {
        "Destinations": {
          "default": { "Address": "http://localhost:5155" }
        }
      }
    }
  }
}
