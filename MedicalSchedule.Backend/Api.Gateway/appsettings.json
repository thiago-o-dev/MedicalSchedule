{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "registry-route": {
        "ClusterId": "registry-cluster",
        "Match": {
          "Path": "/registry/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/registry"
          }
        ]
      },

      "scheduling-route": {
        "ClusterId": "scheduling-cluster",
        "Match": {
          "Path": "/scheduling/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/scheduling"
          }
        ]
      },

      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/payments"
          }
        ]
      },

      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notifications"
          }
        ]
      },

      "whatsapp-route": {
        "ClusterId": "whatsapp-cluster",
        "Match": {
          "Path": "/whatsapp/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/whatsapp"
          }
        ]
      }
    },

    "Clusters": {
      "registry-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://registry"
          }
        }
      },

      "scheduling-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://scheduling"
          }
        }
      },

      "payments-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://payments"
          }
        }
      },

      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://notifications"
          }
        }
      },

      "whatsapp-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://whatsappbot"
          }
        }
      }
    }
  }
}
